# LLM Provider - choose: ollama | openai | claude | featherless
LLM_PROVIDER=ollama

# Ollama (default - runs locally)
OLLAMA_MODEL=llama3.1:8b
# OLLAMA_BASE_URL=http://ollama:11434   # set automatically in docker-compose

# OpenAI (optional)
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o

# Claude (optional - best report quality)
# LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# Featherless AI (sponsor - access to 100+ open-source models)
# LLM_PROVIDER=featherless
# FEATHERLESS_API_KEY=rc_...
# FEATHERLESS_MODEL=meta-llama/Meta-Llama-3.1-8B-Instruct

# n8n webhook - paste your n8n webhook URL here to enable scan completion notifications
N8N_WEBHOOK_URL=

# Base URL for report links sent in n8n notifications
LUMINA_BASE_URL=http://localhost:3000

# Security - comma-separated allowlisted scan targets
ALLOWED_TARGETS=target,localhost,127.0.0.1
